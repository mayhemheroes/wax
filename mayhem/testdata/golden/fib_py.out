# === User Code            BEGIN ===

def fib(i):
    
    if int((i)<=(1)):
        return i

    return ((fib(((i)-(1))))+(fib(((i)-(2)))))

def main():
    
    x=0
    x=fib(9)
    print(str(x))
    return 0

# === User Code            END   ===
exit(main())
